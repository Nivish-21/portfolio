# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# gstack local tooling state (logs, not project content)
/.gstack

# typescript
*.tsbuildinfo
next-env.d.ts

# stray runtime lock files (not project content)
.claude/scheduled_tasks.lock

# internal working docs / process notes / personal files — this repo is public,
# keep it to code only
/docs/
/PRODUCT.md
.gstack/
